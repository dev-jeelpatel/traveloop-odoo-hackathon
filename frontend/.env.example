# ── Traveloop Frontend — Environment Variables ─────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── API Base URL ────────────────────────────────────────────────────────────────
# Local development (uses Vite proxy — no CORS issues):
VITE_API_URL=/api

# Production (point to your Render.com backend URL):
# VITE_API_URL=https://traveloop-api.onrender.com/api
